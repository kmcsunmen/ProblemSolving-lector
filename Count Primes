int countPrimes(int n) {
    int cnt = 0;
    int* visited = (int*)malloc(sizeof(int) * (n+1));
    for(int i=0; i<=n; i++) visited[i] = 0;

    for(int i=2; i<n; i++){
        if(visited[i] == 0){
            for(int j=2; i*j<n; j++){
                visited[i*j]++;
            }
        }
    }
    for(int i=2; i<n; i++){
        if(visited[i] == 0) cnt++;
    }
    return cnt;
}
